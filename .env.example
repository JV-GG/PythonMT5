# MT5 Connection (your MT5 account on the Windows laptop)
MT5_LOGIN=your_mt5_login_here
MT5_PASSWORD=your_mt5_password_here
MT5_SERVER=your_mt5_server_here

# IMPORTANT: Point to your Mac's IP address
SIGNALTRADE_URL=http://your_mac_ip_here

# Other settings
SIGNALTRADE_POLL_INTERVAL=60
DEFAULT_VOLUME=0.01
API_KEY=your_api_key_here
HOST=0.0.0.0
PORT=8000

SPREAD_BUFFER_MULTIPLIER=1.0
